    "editor.wordHighlightStrongBackground": "#FFBA4A28",
    "editor.findMatchBackground": "#FFBA4A40",
    "editor.findMatchHighlightBackground": "#FFBA4A20",
    "editor.rangeHighlightBackground": "#FFBA4A10",
    "editorCursor.foreground": "#FFBA4A",
    "editorWhitespace.foreground": "#2A221A",
    "editorIndentGuide.background": "#2A221A",
    "editorIndentGuide.activeBackground": "#483620",
    "editorLineNumber.foreground": "#8C7454",
    "editorLineNumber.activeForeground": "#C4A878",
    "editorRuler.foreground": "#2A221A",
    "editorBracketMatch.background": "#FFBA4A25",
    "editorBracketMatch.border": "#FFBA4A50",
    "editorOverviewRuler.border": "#2A221A00",
    "editorGutter.background": "#14100C",
    "editorBracketHighlight.foreground1": "#FFBA4A",
    "editorBracketHighlight.foreground2": "#FF9A20",
    "editorBracketHighlight.foreground3": "#5EEAD4",
    "editorBracketHighlight.foreground4": "#D8B4FE",
    "editorBracketHighlight.foreground5": "#93C5FD",
    "editorBracketHighlight.foreground6": "#FCA5A5",
    "titleBar.activeBackground": "#14100C",
    "titleBar.activeForeground": "#F8F0E0",
    "titleBar.inactiveBackground": "#14100C",
    "titleBar.inactiveForeground": "#8C7454",
    "titleBar.border": "#785834",
    "activityBar.background": "#14100C",
    "activityBar.foreground": "#FFBA4A",
    "activityBar.inactiveForeground": "#785834",
    "activityBar.border": "#785834",
    "activityBarBadge.background": "#FF9A20",
    "activityBarBadge.foreground": "#14100C",
    "activityBar.activeBorder": "#FFBA4A",
    "sideBar.background": "#1E1812",
    "sideBar.foreground": "#F8F0E0",
    "sideBar.border": "#785834",
    "sideBarTitle.foreground": "#FFBA4A",
    "sideBarSectionHeader.background": "#14100C",
    "sideBarSectionHeader.foreground": "#C4A878",
    "sideBarSectionHeader.border": "#785834",
    "list.activeSelectionBackground": "#2A221A",
    "list.activeSelectionForeground": "#F8F0E0",
    "list.hoverBackground": "#1E1812",
    "list.hoverForeground": "#F8F0E0",
    "list.inactiveSelectionBackground": "#1E1812",
    "list.inactiveSelectionForeground": "#F8F0E0",
    "list.highlightForeground": "#FFBA4A",
    "list.focusOutline": "#FFBA4A50",
    "editorGroupHeader.tabsBackground": "#14100C",
    "editorGroupHeader.tabsBorder": "#785834",
    "tab.activeBackground": "#1E1812",
    "tab.activeForeground": "#FFBA4A",
    "tab.activeBorder": "#00000000",
    "tab.activeBorderTop": "#FFBA4A",
    "tab.inactiveBackground": "#14100C",
    "tab.inactiveForeground": "#8C7454",
    "tab.border": "#785834",
    "tab.hoverBackground": "#1E1812",
    "statusBar.background": "#14100C",
    "statusBar.foreground": "#C4A878",
    "statusBar.border": "#785834",
    "statusBar.noFolderBackground": "#14100C",
    "statusBar.debuggingBackground": "#FF9A20",
    "statusBar.debuggingForeground": "#14100C",
    "statusBarItem.remoteBackground": "#785834",
    "statusBarItem.remoteForeground": "#F8F0E0",
    "statusBarItem.hoverBackground": "#2A221A",
    "panel.background": "#14100C",
    "panel.border": "#785834",
    "panelTitle.activeBorder": "#FFBA4A",
    "panelTitle.activeForeground": "#FFBA4A",
    "panelTitle.inactiveForeground": "#8C7454",
    "terminal.background": "#14100C",
    "terminal.foreground": "#F8F0E0",
    "terminal.ansiBlack": "#1E1812",
    "terminal.ansiRed": "#FCA5A5",
    "terminal.ansiGreen": "#4ADE80",
    "terminal.ansiYellow": "#FFBA4A",
    "terminal.ansiBlue": "#93C5FD",
    "terminal.ansiMagenta": "#D8B4FE",
    "terminal.ansiCyan": "#5EEAD4",
    "terminal.ansiWhite": "#F8F0E0",
    "terminal.ansiBrightBlack": "#785834",
    "terminal.ansiBrightRed": "#FCA5A5",
    "terminal.ansiBrightGreen": "#4ADE80",
    "terminal.ansiBrightYellow": "#FF9A20",
    "terminal.ansiBrightBlue": "#93C5FD",
    "terminal.ansiBrightMagenta": "#F472B6",
    "terminal.ansiBrightCyan": "#5EEAD4",
    "terminal.ansiBrightWhite": "#FFFFFF",
    "terminalCursor.foreground": "#FFBA4A",
    "input.background": "#1E1812",
    "input.foreground": "#F8F0E0",
    "input.border": "#785834",
    "input.placeholderForeground": "#8C7454",
    "inputOption.activeBorder": "#FFBA4A",
    "inputOption.activeBackground": "#FFBA4A20",
    "inputOption.activeForeground": "#FFBA4A",
    "dropdown.background": "#1E1812",
    "dropdown.border": "#785834",
    "dropdown.foreground": "#F8F0E0",
    "focusBorder": "#FFBA4A80",
    "button.background": "#FFBA4A",
    "button.foreground": "#14100C",
    "button.hoverBackground": "#FF9A20",
    "button.secondaryBackground": "#2A221A",
    "button.secondaryForeground": "#FFBA4A",
    "button.secondaryHoverBackground": "#483620",
    "badge.background": "#FF9A20",
    "badge.foreground": "#14100C",
    "notificationCenterHeader.background": "#1E1812",
    "notifications.background": "#1E1812",
    "notifications.border": "#785834",
    "scrollbar.shadow": "#00000040",
    "scrollbarSlider.background": "#78583440",
    "scrollbarSlider.hoverBackground": "#78583460",
    "scrollbarSlider.activeBackground": "#78583480",
    "minimap.background": "#14100C",
    "minimap.selectionHighlight": "#FFBA4A40",
    "minimap.findMatchHighlight": "#FF9A2060",
    "peekView.border": "#785834",
    "peekViewEditor.background": "#1E1812",
    "peekViewResult.background": "#14100C",
    "peekViewTitle.background": "#14100C",
    "peekViewTitleLabel.foreground": "#FFBA4A",
    "peekViewTitleDescription.foreground": "#C4A878",
    "peekViewResult.matchHighlightBackground": "#FFBA4A30",
    "peekViewEditor.matchHighlightBackground": "#FFBA4A30",
    "diffEditor.insertedTextBackground": "#4ADE8020",
    "diffEditor.removedTextBackground": "#FCA5A520",
    "gitDecoration.addedResourceForeground": "#4ADE80",
    "gitDecoration.modifiedResourceForeground": "#FFBA4A",
    "gitDecoration.deletedResourceForeground": "#FCA5A5",
    "gitDecoration.untrackedResourceForeground": "#5EEAD4",
    "gitDecoration.ignoredResourceForeground": "#483620",
    "gitDecoration.conflictingResourceForeground": "#FF9A20",
    "editorError.foreground": "#FCA5A5",
    "editorWarning.foreground": "#FFBA4A",
    "editorInfo.foreground": "#93C5FD",
    "editorHint.foreground": "#5EEAD4",
    "editorWidget.background": "#1E1812",
    "editorWidget.foreground": "#F8F0E0",
    "editorWidget.border": "#785834",
    "editorSuggestWidget.background": "#1E1812",
    "editorSuggestWidget.border": "#785834",
    "editorSuggestWidget.selectedBackground": "#2A221A",
    "editorSuggestWidget.highlightForeground": "#FFBA4A",
    "quickInput.background": "#1E1812",
    "quickInput.foreground": "#F8F0E0",
    "quickInputList.focusBackground": "#2A221A",
    "quickInputList.focusForeground": "#F8F0E0",
    "quickInputTitle.background": "#14100C",
    "breadcrumb.foreground": "#8C7454",
    "breadcrumb.focusForeground": "#F8F0E0",
    "breadcrumb.activeSelectionForeground": "#FFBA4A",
    "breadcrumbPicker.background": "#1E1812",
    "welcomePage.background": "#14100C",
    "walkThrough.embeddedEditorBackground": "#1E1812",
    "textLink.foreground": "#FFBA4A",
    "textLink.activeForeground": "#FF9A20"
  },
  "tokenColors": [
    { "name": "Comments", "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#8C7454", "fontStyle": "italic" } },
    { "name": "Strings", "scope": ["string", "string.quoted", "string.template", "punctuation.definition.string"], "settings": { "foreground": "#4ADE80" } },
    { "name": "String Escapes", "scope": ["constant.character.escape"], "settings": { "foreground": "#5EEAD4" } },
    { "name": "Template Expressions", "scope": ["string.template punctuation.definition.template-expression", "string.template meta.template.expression"], "settings": { "foreground": "#FFBA4A" } },
    { "name": "Keywords", "scope": ["keyword", "keyword.control", "keyword.operator.new", "keyword.operator.expression", "keyword.operator.logical", "keyword.operator.delete", "keyword.operator.typeof", "keyword.operator.instanceof", "keyword.operator.void", "keyword.operator.in", "keyword.operator.of", "storage.type", "storage.modifier"], "settings": { "foreground": "#FFBA4A" } },
    { "name": "Control Flow", "scope": ["keyword.control.flow", "keyword.control.return", "keyword.control.conditional", "keyword.control.loop", "keyword.control.trycatch", "keyword.control.import", "keyword.control.export", "keyword.control.from"], "settings": { "foreground": "#FFBA4A", "fontStyle": "italic" } },
    { "name": "Operators", "scope": ["keyword.operator", "keyword.operator.assignment", "keyword.operator.arithmetic", "keyword.operator.comparison", "keyword.operator.ternary"], "settings": { "foreground": "#C4A878" } },
    { "name": "Functions", "scope": ["entity.name.function", "meta.function-call entity.name.function", "support.function", "meta.function-call"], "settings": { "foreground": "#93C5FD" } },
    { "name": "Function Parameters", "scope": ["variable.parameter", "meta.parameters variable.parameter"], "settings": { "foreground": "#FF9A20", "fontStyle": "italic" } },
    { "name": "Variables", "scope": ["variable", "variable.other"], "settings": { "foreground": "#F8F0E0" } },
    { "name": "Variable Properties", "scope": ["variable.other.property", "variable.other.object.property", "meta.object-literal.key"], "settings": { "foreground": "#D8CEB8" } },
    { "name": "Language Variables", "scope": ["variable.language"], "settings": { "foreground": "#FFBA4A", "fontStyle": "italic" } },
    { "name": "Types & Classes", "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class", "entity.other.inherited-class"], "settings": { "foreground": "#D8B4FE" } },
    { "name": "Type Parameters", "scope": ["entity.name.type.parameter"], "settings": { "foreground": "#F472B6" } },
    { "name": "Interfaces", "scope": ["entity.name.type.interface"], "settings": { "foreground": "#5EEAD4" } },
    { "name": "Constants", "scope": ["constant", "constant.language", "constant.language.boolean", "constant.language.null", "constant.language.undefined", "support.constant"], "settings": { "foreground": "#FF9A20" } },
    { "name": "Numbers", "scope": ["constant.numeric", "constant.numeric.integer", "constant.numeric.float", "constant.numeric.hex"], "settings": { "foreground": "#5EEAD4" } },
    { "name": "Punctuation", "scope": ["punctuation.definition.block", "punctuation.separator", "punctuation.terminator", "punctuation.accessor", "meta.brace"], "settings": { "foreground": "#785834" } },
    { "name": "HTML/JSX Tags", "scope": ["entity.name.tag", "punctuation.definition.tag"], "settings": { "foreground": "#FCA5A5" } },
    { "name": "HTML/JSX Attributes", "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#FF9A20", "fontStyle": "italic" } },
    { "name": "JSX Component Tags", "scope": ["support.class.component"], "settings": { "foreground": "#D8B4FE" } },
    { "name": "CSS Properties", "scope": ["support.type.property-name.css"], "settings": { "foreground": "#93C5FD" } },
    { "name": "CSS Values", "scope": ["support.constant.property-value.css", "meta.property-value.css"], "settings": { "foreground": "#5EEAD4" } },
    { "name": "CSS Selectors", "scope": ["entity.name.tag.css", "entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"], "settings": { "foreground": "#FFBA4A" } },
    { "name": "Markdown Headings", "scope": ["heading.1.markdown", "heading.2.markdown", "heading.3.markdown", "heading.4.markdown", "markup.heading"], "settings": { "foreground": "#FFBA4A", "fontStyle": "bold" } },
    { "name": "Markdown Links", "scope": ["markup.underline.link", "string.other.link"], "settings": { "foreground": "#93C5FD" } },
    { "name": "Markdown Code", "scope": ["markup.inline.raw", "markup.fenced_code.block"], "settings": { "foreground": "#5EEAD4" } },
    { "name": "JSON Keys", "scope": ["support.type.property-name.json"], "settings": { "foreground": "#FFBA4A" } },
    { "name": "Python Self", "scope": ["variable.parameter.function.language.special.self.python"], "settings": { "foreground": "#FFBA4A", "fontStyle": "italic" } },
    { "name": "Python Decorators", "scope": ["entity.name.function.decorator.python", "meta.function.decorator.python"], "settings": { "foreground": "#FF9A20", "fontStyle": "italic" } },
    { "name": "Rust Macros", "scope": ["entity.name.function.macro.rust"], "settings": { "foreground": "#FF9A20", "fontStyle": "bold" } },
    { "name": "Regex", "scope": ["string.regexp", "constant.other.character-class.regexp"], "settings": { "foreground": "#FB923C" } },
    { "name": "Decorators", "scope": ["meta.decorator", "meta.annotation", "storage.type.annotation"], "settings": { "foreground": "#FF9A20" } },
    { "name": "Namespaces", "scope": ["entity.name.namespace", "entity.name.module", "entity.name.import"], "settings": { "foreground": "#5EEAD4" } },
    { "name": "Built-in", "scope": ["support.variable", "support.other"], "settings": { "foreground": "#93C5FD" } },
    { "name": "Enum Members", "scope": ["variable.other.enummember"], "settings": { "foreground": "#5EEAD4" } }
  ],
  "semanticTokenColors": {
    "type": "#D8B4FE", "class": "#D8B4FE", "interface": "#5EEAD4", "enum": "#D8B4FE",
    "enumMember": "#5EEAD4", "function": "#93C5FD", "method": "#93C5FD", "macro": "#FF9A20",
    "variable": "#F8F0E0", "parameter": "#FF9A20", "property": "#D8CEB8", "namespace": "#5EEAD4",
    "decorator": "#FF9A20", "typeParameter": "#F472B6"
  }
}
