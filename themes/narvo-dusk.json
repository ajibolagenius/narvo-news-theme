{
  "$schema": "vscode://schemas/color-theme",
  "name": "Narvo Dusk",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#14100C",
    "editor.foreground": "#F8F0E0",
    "editor.lineHighlightBackground": "#1E1812",
    "editor.lineHighlightBorder": "#1E181200",
    "editor.selectionBackground": "#FFBA4A35",
